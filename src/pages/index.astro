---
import BaseLayout from "../layouts/BaseLayout.astro";
import Profile from "../components/Profile.astro";
import Interests from "../components/Interests.astro";
import Links from "../components/Links.astro";
import myIcon from "../assets/no2ca.svg";
import Projects from "../components/Projects.astro";

const name = "nonica";
const update = "2026-03-30";
const description = `
低レイヤ / OS開発を中心に学んでいる大学3年生です.
`;
const interests = ["OS", "Rust", "RISC-V", "x86", "Compiler"];

const links = [
  { name: "GitHub", url: "https://github.com/no2ca" },
  { name: "Cosense (Scrapbox)", url: "https://cosen.se/nonica" },
  { name: "Qiita", url: "https://qiita.com/nonica" },
  {
    name: "Bluesky",
    url: "https://bsky.app/profile/did:plc:wvwzypmkkewmn3yaedrpzncd",
  },
  { name: "X", url: "https://x.com/no2cax" },
];

const projects = [
  {
    name: "nex_os",
    description: "RISC-Vで動作するOS",
    url: "https://github.com/no2ca/nex_os",
  },
  {
    name: "lifegame",
    description: "ベアメタルのx86で動くライフゲーム",
    url: "https://github.com/no2ca/lifegame",
  },
  {
    name: "nonicc",
    description: "x86_64をターゲットにしたCコンパイラ",
    url: "https://github.com/no2ca/nonicc",
  },
];
---

<BaseLayout title="nonica | Home Page">
  <div class="reveal" style="--reveal-delay: 0ms;">
    <Profile {myIcon} {name} {update} />
  </div>
  <div class="reveal" style="--reveal-delay: 70ms;">
    <Interests {description} {interests} />
  </div>
  <div class="reveal" style="--reveal-delay: 120ms;">
    <Links {links} />
  </div>
  <div class="reveal" style="--reveal-delay: 170ms;">
    <Projects {projects} />
  </div>
</BaseLayout>

<style>
  .reveal {
    animation: rise 420ms ease both;
    animation-delay: var(--reveal-delay, 0ms);
  }

  .reveal + .reveal {
    margin-top: clamp(1.4rem, 3vw, 2rem);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
    }
  }
</style>
