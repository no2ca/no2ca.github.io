---
export interface Props {
  projects: {
    name: string;
    description: string;
    url: string;
  }[];
}
const { projects } = Astro.props;
---

<section>
  <h2>Projects</h2>
  <ul class="project-list">
    {
      projects.map((project) => (
        <li class="project">
          <a class="name" href={project.url} target="_blank" rel="noreferrer">
            {project.name}
          </a>
          <p>{project.description}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .project-list {
    margin: 0;
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .project {
    padding: 0.2rem 0 0.9rem;
    border-bottom: 1px solid var(--line);
  }

  .project:first-child {
    border-top: 1px solid var(--line);
    padding-top: 0.66rem;
  }

  .name {
    display: inline-block;
    font-family:
      "Zen Kaku Gothic New",
      "Noto Sans JP",
      "Hiragino Sans",
      "Yu Gothic",
      sans-serif;
    font-size: 1.13rem;
    font-weight: 400;
    letter-spacing: 0.018em;
    color: var(--fg);
    text-decoration: none;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .name:hover {
    color: var(--accent);
    transform: translateX(1px);
  }

  .project p {
    margin-top: 0.24rem;
    color: var(--muted);
    font-size: 0.93rem;
    font-weight: 300;
  }
</style>
