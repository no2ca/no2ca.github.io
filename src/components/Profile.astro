---
export interface Props {
  myIcon: any;
  name: any;
  update: any;
}
const { myIcon, name, update } = Astro.props;
---

<section class="profile">
  <div class="avatar">
    <img src={myIcon.src} alt="Profile icon" />
  </div>

  <div class="content">
    <h1>{name}</h1>
    <p class="muted">Last updated: {update}</p>
  </div>
</section>

<style>
  .profile {
    gap: 1rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid var(--line);
  }

  .avatar {
    display: flex;
    justify-self: start;
  }

  .avatar img {
    width: 100px;
    height: 100px;
    border: 1px solid var(--line);
    object-fit: cover;
  }

  .content {
    margin-top: 1rem;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 1rem;
  }

  h1 {
    font-size: clamp(1.75rem, 5vw, 2.20rem);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: 0.015em;
  }

  .muted {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 300;
    font-family: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
  }

  @media screen and (max-width: 680px) {
    .profile {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 0.9rem;
    }

    .content {
      align-items: baseline;
    }

    .avatar img {
      width: 96px;
      height: 96px;
    }
  }
</style>
