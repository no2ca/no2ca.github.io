---
import "../styles/global.css";
const { title = "nonica | website", bodyClass = "" } = Astro.props;
const gaId = (import.meta.env.PUBLIC_GA_ID?.trim() || "G-F3YRJ3XXWK").trim();
---

<!doctype html>
<html lang="ja">
  <head>
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("theme");
          if (savedTheme === "light" || savedTheme === "dark") {
            document.documentElement.dataset.theme = savedTheme;
          }
        } catch {
          // ignore storage errors
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400&family=Noto+Sans+JP:wght@200;300;400;500&family=Zen+Kaku+Gothic+New:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {
      gaId && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          ></script>
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaId);
          </script>
        </>
      )
    }
  </head>

  <body class={bodyClass}>
    <main class="container">
      <div class="toolbar">
        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-live="polite"
        >
          <span data-theme-toggle-label>Dark mode</span>
        </button>
      </div>
      <slot />
      <footer class="site-footer">
        <a href="/privacy-policy">プライバシーポリシー</a>
      </footer>
    </main>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.querySelector("[data-theme-toggle]");
        const label = document.querySelector("[data-theme-toggle-label]");

        if (!button || !label) {
          return;
        }

        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");

        const currentTheme = () => {
          if (root.dataset.theme === "dark" || root.dataset.theme === "light") {
            return root.dataset.theme;
          }

          return prefersDark.matches ? "dark" : "light";
        };

        const syncButtonText = (theme) => {
          const nextLabel = theme === "dark" ? "Light mode" : "Dark mode";
          label.textContent = nextLabel;
          button.setAttribute(
            "aria-label",
            `Switch to ${nextLabel.toLowerCase()}`,
          );
        };

        const setTheme = (theme, withTransition) => {
          const applyTheme = () => {
            root.dataset.theme = theme;
            syncButtonText(theme);
          };

          if (
            withTransition &&
            "startViewTransition" in document &&
            !reducedMotion.matches
          ) {
            document.startViewTransition(applyTheme);
            return;
          }

          applyTheme();
        };

        setTheme(currentTheme(), false);

        button.addEventListener("click", () => {
          const nextTheme = currentTheme() === "dark" ? "light" : "dark";

          try {
            localStorage.setItem("theme", nextTheme);
          } catch {
            // ignore storage errors
          }

          setTheme(nextTheme, true);
        });
      })();
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #edf0f3;
    --bg-soft: #f4f6f8;
    --fg: #313842;
    --muted: #5d6570;
    --accent: #4f6b8f;
    --line: #ccd3dc;
    --bg-glow: rgba(255, 255, 255, 0.56);
    color-scheme: light;
  }

  :root[data-theme="dark"] {
    --bg: #2e2e2e;
    --bg-soft: #484848;
    --fg: #d7dee7;
    --muted: #a6b3c4;
    --accent: #859dbd;
    --line: #94a2b6;
    --bg-glow: rgba(133, 157, 189, 0.12);
    color-scheme: dark;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) {
      --bg: #14191f;
      --bg-soft: #1a2028;
      --fg: #d7dee7;
      --muted: #9eabbb;
      --accent: #859dbd;
      --line: #374250;
      --bg-glow: rgba(133, 157, 189, 0.12);
      color-scheme: dark;
    }
  }

  body {
    margin: 0;
    font-family:
      "Noto Sans JP", "Zen Kaku Gothic New", "Hiragino Sans", "Yu Gothic",
      "Meiryo", sans-serif;
    font-weight: 300;
    background:
      radial-gradient(
        1000px 520px at 14% -12%,
        var(--bg-glow) 0%,
        rgba(0, 0, 0, 0) 62%
      ),
      linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
    color: var(--fg);
    line-height: 1.84;
    letter-spacing: 0.012em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(2.4rem, 5vw, 4rem) clamp(1.1rem, 4vw, 2rem) 4rem;
  }

  .toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: clamp(0.5rem, 1vw, 0.9rem);
  }

  .theme-toggle {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
    padding: 0.22rem 0.56rem;
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .site-footer {
    margin-top: clamp(3rem, 8vw, 5rem);
    text-align: center;
    font-size: 0.78rem;
    color: var(--muted);
    opacity: 0.72;
  }

  .site-footer a {
    transition: color 0.2s ease;
  }

  .site-footer a:hover {
    color: var(--muted);
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 220ms;
    animation-timing-function: ease;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 0ms;
    }
  }
</style>
